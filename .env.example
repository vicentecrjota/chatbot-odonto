# Copie este arquivo para .env e preencha os valores.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase > Settings > API

# Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# anon/public key (usada no frontend — escopo limitado)
SUPABASE_ANON_KEY=

# service_role key (SECRETA — acesso total ao banco, nunca expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Banco de dados direto (PostgreSQL) ──────────────────────────────────────
# Supabase > Settings > Database > Connection string > URI
# Necessário para o RAG (psycopg / pgvector)
# Exemplo: postgresql://postgres:[SENHA]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# platform.openai.com > API Keys
OPENAI_API_KEY=sk-...

# ─── Meta (WhatsApp + Instagram) ─────────────────────────────────────────────
# Meta Developers > seu app > WhatsApp > Configuration

# Token que você inventa — deve ser igual ao configurado no painel da Meta
META_VERIFY_TOKEN=

# Meta Developers > seu app > Settings > Basic > App Secret
META_APP_SECRET=

# Meta Developers > WhatsApp > API Setup > Access Token
META_ACCESS_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
